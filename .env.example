# KiForge Arena environment template
# Copy to .env and fill only the integrations you are using.

# Backend server
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
UNITY_WS_URL=ws://127.0.0.1:8000/ws/unity
AGENT_COMBAT_ENDPOINT=http://127.0.0.1:8000/agent/combat

# Redis memory. Leave blank to use the in-memory fallback.
# Use a Redis Stack instance (e.g. Redis Cloud, or `docker run redis/redis-stack`)
# to unlock RediSearch vector recall for the boss's associative memory; a plain
# Redis still powers streams, TTL cooldowns, pub/sub, and JSON memory.
# Example: redis://default:<password>@<host>:<port>
REDIS_URL=

# Pika recap queue/API. The queue works locally without an API key.
PIKA_API_KEY=
PIKA_RECAP_QUEUE=backend/recap_jobs.jsonl

# Arize / Phoenix fight lab tracing.
ARIZE_API_KEY=
ARIZE_SPACE_ID=
PHOENIX_COLLECTOR_ENDPOINT=

# Fetch.ai / Agentverse / ASI:One.
# ASI_ONE_API_KEY enables live LLM narration/coaching; leave blank for the
# deterministic fallback. Override base URL/model only if not using ASI:One.
FETCH_AI_AGENT_SEED=
AGENTVERSE_API_KEY=
ASI_ONE_API_KEY=
ASI_ONE_BASE_URL=https://api.asi1.ai/v1
ASI_ONE_MODEL=asi1-mini

# Optional sponsor integrations.
DEEPGRAM_API_KEY=
BAND_API_KEY=
SENTRY_DSN=

# Hardware/input toggles.
MYO_ENABLED=false
MYO_DEVICE_NAME=
CV_CAMERA_INDEX=0
CV_TARGET_FPS=30
